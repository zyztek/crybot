# Test Environment Configuration
# Use this for running integration tests

NODE_ENV=test

# Test Database - Update with your PostgreSQL connection string
# Format: postgresql://user:password@host:5432/crybot_test
TEST_DATABASE_URL="postgresql://postgres:password@localhost:5432/crybot_test?schema=public"

# JWT - Use a different secret for tests
JWT_SECRET=test-secret-key-minimum-32-characters-long

# CORS - Allow any origin for tests
CORS_ORIGIN="http://localhost:3000"

# Rate limiting - more lenient for tests
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000