{
  "name": "crybot-backend",
  "version": "1.0.0",
  "description": "CryptoFaucet Hub Backend API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:staging": "NODE_ENV=staging tsx watch src/index.ts",
    "dev:production": "NODE_ENV=production tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:staging": "NODE_ENV=staging node dist/index.js",
    "start:production": "NODE_ENV=production node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "test": "vitest run --exclude '**/api.integration.test.ts'",
    "test:watch": "vitest",
    "test:setup-db": "npx tsx scripts/setup-test-db.ts",
    "test:integration": "npm run test:setup-db && NODE_ENV=test vitest run src/routes/api.integration.test.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.31",
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "ethers": "^6.13.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "graphql": "^16.13.2",
    "graphql-yoga": "^5.18.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.3.0",
    "morgan": "^1.10.0",
    "openai": "^4.77.0",
    "p-queue": "^8.0.1",
    "uuid": "^13.0.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.5.12",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "bn.js": ">=4.12.3",
    "elliptic": ">=6.5.7"
  }
}