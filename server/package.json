{
  "name": "crybot-backend",
  "version": "1.0.0",
  "description": "CryptoFaucet Hub Backend API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:staging": "NODE_ENV=staging tsx watch src/index.ts",
    "dev:production": "NODE_ENV=production tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:staging": "NODE_ENV=staging node dist/index.js",
    "start:production": "NODE_ENV=production node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "test": "vitest run --exclude '**/api.integration.test.ts'",
    "test:watch": "vitest",
    "test:setup-db": "npx tsx scripts/setup-test-db.ts",
    "test:integration": "npm run test:setup-db && NODE_ENV=test vitest run src/routes/api.integration.test.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "bitcore-lib": "^8.25.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "express": "^4.21.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.9.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
