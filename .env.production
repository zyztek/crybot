# Production Environment
# Frontend production settings only

# API Configuration
VITE_API_URL=https://api.cryptofaucethub.com/api
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_REFERRAL=true
VITE_ENABLE_LEADERBOARD=true
VITE_ENABLE_ADVANCED_ANALYTICS=true

# App Configuration
VITE_APP_NAME=CryptoFaucet Hub
VITE_APP_VERSION=1.0.0
VITE_DEFAULT_NETWORK=mainnet
VITE_SUPPORTED_NETWORKS=mainnet,arbitrum,optimism

