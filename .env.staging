# Staging Environment
# Frontend staging settings

# API Configuration
VITE_API_URL=https://staging-api.cryptofaucethub.com/api
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_REFERRAL=true
VITE_ENABLE_LEADERBOARD=true
VITE_ENABLE_ADVANCED_ANALYTICS=true

# App Configuration
VITE_APP_NAME=CryptoFaucet Hub (Staging)
VITE_APP_VERSION=1.0.0-staging
VITE_DEFAULT_NETWORK=sepolia
VITE_SUPPORTED_NETWORKS=sepolia,mainnet,arbitrum,optimism