{
  "name": "crybot",
  "version": "1.0.0",
  "description": "CryptoFaucet Hub - Multi-chain cryptocurrency faucet platform",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:production": "tsc && vite build --mode production",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "node scripts/setup-wizard.js",
    "setup:auto": "npm run setup:auto:win || npm run setup:auto:mac",
    "setup:auto:win": "scripts\\auto-setup.bat",
    "setup:auto:mac": "bash scripts/auto-setup.sh",
    "lint": "eslint src --ext ts,tsx",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.0",
    "recharts": "^2.13.0",
    "lucide-react": "^0.469.0",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.6.0",
    "vite": "^8.0.3",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "author": "CryptoFaucet Hub Team",
  "license": "MIT",
  "homepage": "https://github.com/zyztek/crybot#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/zyztek/crybot.git"
  },
  "keywords": [
    "cryptocurrency",
    "faucet",
    "ethereum",
    "bitcoin",
    "solana",
    "blockchain",
    "testnet",
    "react",
    "typescript"
  ]
}